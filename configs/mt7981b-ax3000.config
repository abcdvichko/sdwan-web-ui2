# OpenWrt 23.05.3 for MT7981B AX3000
# GJ-Link AX3000 固件编译配置
# 版本: 统一使用 openwrt-23.05 分支
#
# 硬件规格:
#   CPU:  MediaTek MT7981B 双核 1.3GHz (ARM Cortex-A53)
#   内存: 256MB DDR3
#   闪存: 128MB SPI NAND
#   2.4G: MT7976GN
#   5G:   MT7976AN
#   网口: 1WAN + 3LAN 千兆自适应
#   无线: AX3000 (2.4G 574Mbps + 5G 2402Mbps)

# ============================================================
# 1. 基础目标配置
# ============================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_mediatek_mt7981_DEVICE_gj-link-ax3000=y

# ============================================================
# 2. 镜像格式与分区大小
# ============================================================
CONFIG_TARGET_KERNEL_PARTSIZE=4
CONFIG_TARGET_ROOTFS_PARTSIZE=100
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256

# ============================================================
# 3. 内核选项
# ============================================================
CONFIG_KERNEL_ARM_PMU=y
CONFIG_KERNEL_PERF_EVENTS=y

# ============================================================
# 4. 无线驱动 (MT7976GN/AN)
# ============================================================
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_kmod-mt7915-firmware=y
CONFIG_PACKAGE_mt7981-wo-firmware=y

# ============================================================
# 5. 交换机与网口支持
# ============================================================
CONFIG_PACKAGE_kmod-dsa=y
CONFIG_PACKAGE_kmod-mt7530=y
CONFIG_PACKAGE_kmod-phylink=y

# ============================================================
# 6. 无线工具与认证
# ============================================================
# 使用 wpad-openssl 替代 wpad-basic-mbedtls 以获得完整功能
CONFIG_PACKAGE_wpad-openssl=y
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y

# ============================================================
# 7. LuCI Web 界面
# ============================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ============================================================
# 8. 网络工具
# ============================================================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_iperf3=y

# ============================================================
# 9. 系统工具
# ============================================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-zram=y

# ============================================================
# 10. 防火墙与 NAT 加速
# ============================================================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-core=y

# ============================================================
# 11. IPv6 支持
# ============================================================
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# ============================================================
# 12. DDNS 动态域名
# ============================================================
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts=y

# ============================================================
# 13. UPnP 端口映射
# ============================================================
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_miniupnpd-nftables=y

# ============================================================
# 14. WireGuard VPN
# ============================================================
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-app-wireguard=y

# ============================================================
# 15. SQM QoS 流量管理
# ============================================================
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_kmod-sched-cake=y

# ============================================================
# 16. 移除不需要的组件以节省空间
# ============================================================
# PPP 拨号（多数使用场景为 DHCP/静态 IP）
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
# CONFIG_PACKAGE_kmod-ppp is not set
# CONFIG_PACKAGE_kmod-pppoe is not set
# CONFIG_PACKAGE_kmod-pppox is not set

# USB 支持（本设备无 USB 接口）
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set

# ============================================================
# 17. 安全与沙箱
# ============================================================
CONFIG_PACKAGE_procd-ujail=y
CONFIG_PACKAGE_procd-seccomp=y

# ============================================================
# 18. SSH 与证书
# ============================================================
CONFIG_PACKAGE_dropbear=y
# dropbear 端口通过 uci-defaults 脚本设置为 5867
CONFIG_PACKAGE_ca-certificates=y

# ============================================================
# 19. 软件包管理
# ============================================================
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_opkg=y

# ============================================================
# 20. 额外工具
# ============================================================
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_vim=y
CONFIG_PACKAGE_openssl-util=y
